RESEND_API_KEY=
NOTIFY_EMAIL=bob@piljay.com
FROM_EMAIL=info@piljay.com

# Required on Vercel (Project Settings → Environment Variables → Production):
# RESEND_API_KEY, NOTIFY_EMAIL, FROM_EMAIL
# FROM_EMAIL must use a domain verified in Resend (e.g. info@piljay.com).
# Public site URL for Open Graph / legal links (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://historic-gross-house.piljay.com
# Legal entity on privacy/terms pages (e.g. your photography company legal name)
NEXT_PUBLIC_SITE_OPERATOR_NAME=

# Optional SMS alerts via Twilio (https://twilio.com) — requires approved A2P 10DLC campaign
# Sends inquiry summary to NOTIFY_PHONE when a contact form is submitted
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
NOTIFY_PHONE=+19123221377
